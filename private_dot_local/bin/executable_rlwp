#!/bin/bash
pkill -f linux-wallpaperengine
pkill waybar
    
linux-wallpaperengine \
        --scaling fill \
        --screen-root DP-2 \
        --bg $1 >/dev/null 2>&1 &
    linux-wallpaperengine \
        --scaling fill \
        --screen-root HDMI-A-2 \
        --bg $2 >/dev/null 2>&1 &

disown
sleep 0.3

waybar >/dev/null 2>&1 &
disown
